# Anthropic Claude API key — used by AI diagnostic report generation and template README writing.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Default model. claude-sonnet-4-6 is recommended; switch to haiku for cheaper calls.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Local SQLite file (relative to repo root). Default: data/agentforge.db.
AGENTFORGE_DB=data/agentforge.db

# Single-tenant auth. When set, every (app)/* and /api/* route requires a
# signed session cookie. Leaving this blank runs the app in OPEN mode
# (intended for local development only — do NOT deploy without it).
AGENTFORGE_PASSWORD=

# Optional: override the HMAC secret used to sign session cookies. Defaults to
# AGENTFORGE_PASSWORD if blank. Rotate this to invalidate all sessions.
AGENTFORGE_SESSION_SECRET=

# Optional consultant info, baked into generated diagnostic reports.
AGENTFORGE_CONSULTANT_NAME=张三
AGENTFORGE_CONSULTANT_TITLE=AI 工作流顾问
AGENTFORGE_CONSULTANT_PHONE=+86 138-0000-0000
AGENTFORGE_CONSULTANT_EMAIL=hello@example.com
