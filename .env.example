# Anthropic Claude API key — used by AI diagnostic report generation and template README writing.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Default model. claude-sonnet-4-6 is recommended; switch to haiku for cheaper calls.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Local SQLite file (relative to repo root). Default: data/agent-flow.db.
AGENTFLOW_DB=data/agent-flow.db

# Single-tenant auth. When set, every (app)/* and /api/* route requires a
# signed session cookie. Leaving this blank runs the app in OPEN mode
# (intended for local development only — do NOT deploy without it).
AGENTFLOW_PASSWORD=

# Optional: override the HMAC secret used to sign session cookies. Defaults to
# AGENTFLOW_PASSWORD if blank. Rotate this to invalidate all sessions.
AGENTFLOW_SESSION_SECRET=

# --- 企业微信 / WeCom (optional; only set if you want bot integration) ---
# Self-built application credentials. All five must be set together;
# leaving any blank disables WeCom integration entirely (callback returns 503).
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=

# Default recipients for proactive event notifications (lead.create etc.).
# "|"-separated userids, or "@all" for everyone in the agent's visible scope.
WECOM_DEFAULT_NOTIFY_USERS=@all

# Optional consultant info, baked into generated diagnostic reports.
AGENTFLOW_CONSULTANT_NAME=张三
AGENTFLOW_CONSULTANT_TITLE=AI 工作流顾问
AGENTFLOW_CONSULTANT_PHONE=+86 138-0000-0000
AGENTFLOW_CONSULTANT_EMAIL=hello@example.com
